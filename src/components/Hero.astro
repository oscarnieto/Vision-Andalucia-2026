---
import { asset } from "../lib/asset";

interface Props {
  image?: string;
  alt?: string;
}
const { image, alt = "" } = Astro.props;
const src = asset(image ?? "");
---

<section class="hero" class:list={[{ "hero--placeholder": !src }]}>
  {src && <img class="hero__img" src={src} alt={alt} />}
  <slot />
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    /* Ocupa el alto de la pantalla restando la cabecera fija */
    height: calc(100svh - var(--altura-cabecera));
    min-height: 420px;
    overflow: hidden;
  }
  .hero--placeholder {
    background: var(--color-gris-placeholder);
  }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
