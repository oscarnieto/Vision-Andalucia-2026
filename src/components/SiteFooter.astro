---
interface MenuItem {
  label: string;
  href: string;
}
interface Contacto {
  titulo: string;
  lineas: string[];
}
interface Props {
  menu: MenuItem[];
  contacto: Contacto;
  disclaimer: string[];
}
import { asset } from "../lib/asset";

const { menu, contacto, disclaimer } = Astro.props;
---

<footer class="footer">
  <div class="contenedor">
    <div class="footer__top">
      <div class="footer__brand">
        <img
          class="footer__savills-img"
          src={asset("img/savills-logo-footer.svg")}
          alt="Savills"
          width="71"
          height="71"
        />
        <img
          class="footer__lockup-img"
          src={asset("img/vision-andalucia-logo-footer.svg")}
          alt="Visión Andalucía 2026"
          width="235"
          height="65"
        />
      </div>

      <div class="footer__contacto">
        <p class="footer__contacto-titulo">{contacto.titulo}</p>
        {contacto.lineas.map((l) => <p class="footer__contacto-linea">{l}</p>)}
      </div>

      {menu.map((m) => <a href={m.href} class="footer__link">{m.label}</a>)}
    </div>

    <div class="footer__disclaimer">
      {disclaimer.map((p) => <p>{p}</p>)}
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-amarillo);
    color: var(--color-negro);
    padding-block: clamp(2.5rem, 5vw, 3.75rem);
  }

  .footer__top {
    display: flex;
    flex-wrap: nowrap;
    gap: 2rem clamp(1.5rem, 3vw, 3rem);
    align-items: flex-start;
    justify-content: space-between;
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  /* --- Marca: logo savills + lockup Visión 2026 Andalucía --- */
  .footer__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .footer__savills-img {
    height: clamp(46px, 5vw, 58px);
    width: auto;
    display: block;
  }
  .footer__lockup-img {
    height: clamp(42px, 4.6vw, 54px);
    width: auto;
    display: block;
  }

  /* --- Contacto --- */
  .footer__contacto-titulo {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .footer__contacto-linea {
    font-size: 0.95rem;
    line-height: 1.55;
  }

  /* --- Menú --- */
  .footer__menu {
    display: flex;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .footer__link {
    font-size: 1.25rem;
    font-weight: 700;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }
  .footer__link:hover {
    opacity: 0.6;
  }

  /* --- Disclaimer --- */
  .footer__disclaimer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 90%;
  }
  .footer__disclaimer p {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  /* En móvil, el footer se apila en una sola columna */
  @media (max-width: 900px) {
    .footer__top {
      flex-direction: column;
      flex-wrap: nowrap;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .footer__brand {
      flex-basis: auto;
    }
    .footer__disclaimer {
      max-width: 100%;
    }
  }
</style>
