---
// Incrusta una gráfica de Infogram. Admite:
//  - `embed`: el <iframe> completo que da Infogram (se inserta tal cual), o
//  - `id`: el data-id del gráfico (usa el script de embed de Infogram).
// Si no se aporta ninguno, muestra un marcador de posición (útil en pruebas).
interface Props {
  embed?: string;
  id?: string;
  titulo?: string;
}
const { embed, id, titulo } = Astro.props;
---

{
  embed ? (
    <div class="infogram" set:html={embed} />
  ) : id ? (
    <div class="infogram infogram-embed" data-id={id} data-type="interactive" />
  ) : (
    <div class="infogram infogram--placeholder">
      <span>Gráfica Infogram{titulo ? ` — ${titulo}` : ""}</span>
    </div>
  )
}

<style>
  .infogram {
    width: 100%;
  }
  .infogram :global(iframe) {
    width: 100% !important;
    border: 0;
  }
  .infogram--placeholder {
    aspect-ratio: 16 / 7;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px dashed rgba(255, 255, 255, 0.35);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
  }
</style>

<script>
  // Carga el loader de Infogram una sola vez, solo si hay gráficas reales
  // (bloques con clase .infogram-embed y un data-id) en la página.
  const w = window as any;
  if (!w.__infogramLoaded && document.querySelector(".infogram-embed")) {
    w.__infogramLoaded = true;
    const s = document.createElement("script");
    s.src = "https://e.infogram.com/js/dist/embed-loader-min.js";
    s.async = true;
    document.body.appendChild(s);
  }
</script>
