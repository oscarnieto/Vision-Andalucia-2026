---
// Incrusta una gráfica de Infogram. Admite:
//  - `embed`: el <iframe> completo que da Infogram (se inserta tal cual), o
//  - `id`: el data-id del gráfico (usa el script de embed de Infogram).
// Si no se aporta ninguno, muestra un marcador de posición (útil en pruebas).
interface Props {
  embed?: string;
  id?: string;
  titulo?: string;
}
const { embed, id, titulo } = Astro.props;

// Aplaza la carga del iframe: cambia src -> data-src para que la gráfica
// NO se descargue durante la carga inicial de la página. Un script la
// activa en cuanto la página termina de cargar (precarga en segundo plano),
// de modo que ya está lista cuando el usuario llega a ella.
const embedDiferido = (embed ?? "").replace(/(<iframe\b[^>]*?)\ssrc=/i, "$1 data-src=");
---

{
  embed ? (
    <div class="infogram" set:html={embedDiferido} />
  ) : id ? (
    <div class="infogram infogram-embed" data-id={id} data-type="interactive" />
  ) : (
    <div class="infogram infogram--placeholder">
      <span>Gráfica Infogram{titulo ? ` — ${titulo}` : ""}</span>
    </div>
  )
}

<style>
  .infogram {
    width: 100%;
  }
  .infogram :global(iframe) {
    width: 100% !important;
    border: 0;
  }
  .infogram--placeholder {
    aspect-ratio: 16 / 7;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.06);
    border: 1px dashed rgba(255, 255, 255, 0.35);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9rem;
  }
</style>

<script>
  // 1) Precarga en segundo plano: una vez cargada la página, activa el src
  //    de los iframes de Infogram aplazados (para que estén listos al llegar).
  const activarGraficas = () => {
    document
      .querySelectorAll<HTMLIFrameElement>(".infogram iframe[data-src]")
      .forEach((f) => {
        f.src = f.getAttribute("data-src") || "";
        f.removeAttribute("data-src");
      });
  };
  if (document.readyState === "complete") activarGraficas();
  else window.addEventListener("load", activarGraficas);

  // 2) Loader de Infogram (solo si se usan gráficas por id, no por embed).
  const w = window as any;
  if (!w.__infogramLoaded && document.querySelector(".infogram-embed")) {
    w.__infogramLoaded = true;
    const s = document.createElement("script");
    s.src = "https://e.infogram.com/js/dist/embed-loader-min.js";
    s.async = true;
    document.body.appendChild(s);
  }
</script>
