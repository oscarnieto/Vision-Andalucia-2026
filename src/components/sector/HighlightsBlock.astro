---
interface Dato {
  numero: string;
  texto: string;
}
interface Props {
  datos: Dato[];
}
const { datos } = Astro.props;
---

<section class="highlights">
  <div class="contenedor">
    <div class="highlights__grid">
      {
        datos.map((d) => (
          <div class="highlight">
            <span class="highlight__num">{d.numero}</span>
            <span class="highlight__txt">{d.texto}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .highlights {
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }
  .highlights__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(0.75rem, 1.6vw, 1.4rem);
  }
  .highlight {
    background: #383a48;
    border-radius: 10px;
    aspect-ratio: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(1rem, 2vw, 1.75rem);
  }
  .highlight__num {
    color: var(--color-amarillo);
    font-weight: 700;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1;
    margin-bottom: 0.6rem;
  }
  .highlight__txt {
    color: #fff;
    font-size: clamp(0.78rem, 1vw, 0.9rem);
    line-height: 1.35;
  }

  /* En móvil, carrusel horizontal con scroll-snap */
  @media (max-width: 780px) {
    .highlights__grid {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 0.75rem;
      padding-bottom: 0.75rem;
      /* Sangría para que la última tarjeta no quede pegada al borde */
      scroll-padding-inline: 1px;
    }
    .highlight {
      flex: 0 0 auto;
      width: 66%;
      max-width: 240px;
      scroll-snap-align: center;
    }
    /* Oculta la barra de scroll manteniendo el gesto */
    .highlights__grid {
      scrollbar-width: none;
    }
    .highlights__grid::-webkit-scrollbar {
      display: none;
    }

    /* Efecto foco: las tarjetas no activas se desenfocan y se
       enfocan suavemente al convertirse en la visible (clase añadida
       por JS; sin JS, todas quedan nítidas). */
    .highlights__grid.hl-carousel .highlight {
      filter: blur(5px);
      opacity: 0.5;
      transform: scale(0.94);
      transition:
        filter 0.4s ease,
        opacity 0.4s ease,
        transform 0.4s ease;
    }
    .highlights__grid.hl-carousel .highlight.is-focus {
      filter: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Efecto foco del carrusel de cifras (solo en móvil): la tarjeta más
  // centrada queda nítida; el resto, desenfocadas. El enfoque transiciona
  // de forma suave vía CSS. Sin JS, ninguna se desenfoca.
  function initHighlights(grid: HTMLElement) {
    const cards = Array.from(grid.children) as HTMLElement[];
    if (!cards.length) return;
    const mq = window.matchMedia("(max-width: 780px)");
    let raf = 0;

    const update = () => {
      if (!mq.matches) {
        grid.classList.remove("hl-carousel");
        cards.forEach((c) => c.classList.remove("is-focus"));
        return;
      }
      grid.classList.add("hl-carousel");
      const gr = grid.getBoundingClientRect();
      const center = gr.left + gr.width / 2;
      let best = cards[0];
      let bestDist = Infinity;
      for (const c of cards) {
        const r = c.getBoundingClientRect();
        const dist = Math.abs(r.left + r.width / 2 - center);
        if (dist < bestDist) {
          bestDist = dist;
          best = c;
        }
      }
      cards.forEach((c) => c.classList.toggle("is-focus", c === best));
    };

    const onScroll = () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(update);
    };

    grid.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", update);
    update();
  }

  document
    .querySelectorAll<HTMLElement>(".highlights__grid")
    .forEach(initHighlights);
</script>
