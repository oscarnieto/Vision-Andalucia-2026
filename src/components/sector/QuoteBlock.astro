---
interface Props {
  texto: string;
  autor?: string;
}
const { texto, autor } = Astro.props;
---

<section class="quote">
  <div class="contenedor">
    <blockquote class="quote__box">
      <p class="quote__texto">{texto}</p>
      {autor && <cite class="quote__autor">{autor}</cite>}
    </blockquote>
  </div>
</section>

<style>
  .quote {
    padding-block: clamp(1.5rem, 4vw, 3rem);
  }
  .quote__box {
    margin: 0;
    border-left: 4px solid var(--color-amarillo);
    padding-left: clamp(1rem, 2.5vw, 2rem);
  }
  .quote__texto {
    font-family: var(--fuente-titulo);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 400;
    line-height: 1.25;
  }
  .quote__autor {
    display: block;
    margin-top: 1rem;
    font-style: normal;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(0.85rem, 1.2vw, 0.95rem);
  }
</style>
