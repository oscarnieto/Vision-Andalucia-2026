---
import { asset } from "../../lib/asset";

interface Props {
  badge?: string;
  titulo: string;
  autor?: string;
  rol?: string;
  image?: string;
}
const { badge, titulo, autor, rol, image } = Astro.props;
const src = asset(image ?? "");
---

<section class="shero" class:list={[{ "shero--placeholder": !src }]}>
  {src && <img class="shero__img" src={src} alt="" />}
  <div class="shero__overlay"></div>
  <div class="contenedor shero__inner">
    <div class="shero__text">
      {badge && <span class="shero__badge">{badge}</span>}
      <h1 class="shero__titulo">{titulo}</h1>
      {
        (autor || rol) && (
          <p class="shero__autor">
            {autor && <span class="shero__autor-nombre">{autor}</span>}
            {rol && <span class="shero__autor-rol">{rol}</span>}
          </p>
        )
      }
    </div>
  </div>
</section>

<style>
  .shero {
    position: relative;
    width: 100%;
    height: calc(100svh - var(--altura-cabecera));
    min-height: 460px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .shero--placeholder {
    background: var(--color-gris-placeholder);
  }
  .shero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Degradado para legibilidad del texto sobre la foto */
  .shero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, 0.6) 0%,
      rgba(0, 0, 0, 0.35) 45%,
      rgba(0, 0, 0, 0) 75%
    );
  }
  .shero__inner {
    position: relative;
    width: 100%;
  }
  .shero__text {
    max-width: 650px;
    color: #fff;
  }
  .shero__badge {
    display: inline-block;
    background: var(--color-amarillo);
    color: var(--color-negro);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: clamp(0.85rem, 1.4vw, 1.05rem);
    padding: 0.4rem 1rem;
    margin-bottom: 1.5rem;
  }
  .shero__titulo {
    font-family: var(--fuente-titulo);
    font-weight: 400;
    font-size: clamp(1.9rem, 4.4vw, 3.125rem);
    line-height: 1.05;
    margin-bottom: 1.75rem;
  }
  .shero__autor {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .shero__autor-nombre {
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    letter-spacing: 0.02em;
  }
  .shero__autor-rol {
    font-size: 0.85rem;
    opacity: 0.9;
  }

  /* En móvil: hero a pantalla completa y texto alineado abajo */
  @media (max-width: 900px) {
    .shero {
      height: 100svh;
      align-items: flex-end;
    }
    .shero__inner {
      padding-bottom: clamp(2.5rem, 8vh, 5rem);
    }
  }
</style>
