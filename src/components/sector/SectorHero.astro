---
import { asset } from "../../lib/asset";

interface Props {
  badge?: string;
  titulo: string;
  autor?: string;
  rol?: string;
  image?: string;
}
const { badge, titulo, autor, rol, image } = Astro.props;
const src = asset(image ?? "");
---

<section class="shero" class:list={[{ "shero--placeholder": !src }]}>
  {src && <img class="shero__img" src={src} alt="" />}
  <div class="shero__grad"></div>
  <div class="contenedor shero__inner">
    <div class="shero__text">
      {badge && <span class="shero__badge">{badge}</span>}
      <h1 class="shero__titulo">{titulo}</h1>
      {
        (autor || rol) && (
          <p class="shero__autor">
            {autor && <strong>{autor}</strong>}{autor && rol ? ", " : ""}{rol && <span>{rol}</span>}
          </p>
        )
      }
    </div>
  </div>
</section>

<style>
  .shero {
    position: relative;
    width: 100%;
    height: calc(100svh - var(--altura-cabecera));
    min-height: 460px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }
  .shero--placeholder {
    background: var(--color-gris-placeholder);
  }
  .shero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Degradado inferior para legibilidad del texto */
  .shero__grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.4) 28%,
      rgba(0, 0, 0, 0) 55%
    );
  }
  .shero__inner {
    position: relative;
    width: 100%;
    padding-bottom: clamp(2rem, 5vh, 3.5rem);
  }
  .shero__text {
    color: #fff;
  }
  .shero__badge {
    display: inline-block;
    background: var(--color-amarillo);
    color: var(--color-negro);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    padding: 0.4rem 1rem;
    margin-bottom: 1.5rem;
  }
  .shero__titulo {
    font-family: var(--fuente-titulo);
    font-weight: 400;
    font-size: clamp(1.9rem, 4.4vw, 3.125rem);
    line-height: 1.05;
    margin-bottom: 1.5rem;
    max-width: 1140px;
  }
  .shero__autor {
    font-size: clamp(0.9rem, 1.2vw, 1rem);
    line-height: 1.4;
  }
  .shero__autor strong {
    font-weight: 700;
  }
  .shero__autor span {
    font-weight: 400;
  }
</style>
