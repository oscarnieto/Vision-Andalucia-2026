---
import Infogram from "./Infogram.astro";

interface Grafica {
  titulo: string;
  embed?: string;
  id?: string;
}
interface Props {
  graficas: Grafica[];
}
const { graficas } = Astro.props;
---

<section class="chart-tabs">
  <div class="contenedor chart-tabs__inner">
    <div class="chart-tabs__panels">
      {
        graficas.map((g, i) => (
          <div class="chart-tabs__panel" data-panel={i} hidden={i !== 0}>
            <Infogram embed={g.embed} id={g.id} titulo={g.titulo} />
          </div>
        ))
      }
    </div>

    {
      graficas.length > 1 && (
        <div class="chart-tabs__botones" role="tablist">
          {graficas.map((g, i) => (
            <button
              class="chart-tabs__btn"
              type="button"
              role="tab"
              data-tab={i}
              aria-selected={i === 0 ? "true" : "false"}
            >
              {g.titulo}
            </button>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .chart-tabs {
    background: #383a48;
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .chart-tabs__panel[hidden] {
    display: none;
  }
  .chart-tabs__botones {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.75rem, 1.6vw, 1.25rem);
    margin-top: clamp(1.5rem, 3vw, 2.25rem);
  }
  .chart-tabs__btn {
    border: 1px solid rgba(255, 255, 255, 0.5);
    background: transparent;
    color: #fff;
    font-family: inherit;
    font-size: clamp(0.75rem, 1vw, 0.85rem);
    line-height: 1.3;
    padding: 0.7rem 1rem;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .chart-tabs__btn:hover {
    border-color: var(--color-amarillo);
  }
  .chart-tabs__btn[aria-selected="true"] {
    background: var(--color-amarillo);
    color: var(--color-negro);
    border-color: var(--color-amarillo);
    font-weight: 600;
  }
  @media (max-width: 720px) {
    .chart-tabs__botones {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".chart-tabs").forEach((root) => {
    const btns = root.querySelectorAll<HTMLElement>(".chart-tabs__btn");
    const panels = root.querySelectorAll<HTMLElement>(".chart-tabs__panel");
    btns.forEach((btn) =>
      btn.addEventListener("click", () => {
        const i = btn.dataset.tab;
        btns.forEach((b) =>
          b.setAttribute("aria-selected", b === btn ? "true" : "false")
        );
        panels.forEach((p) => (p.hidden = p.dataset.panel !== i));
      })
    );
  });
</script>
