---
interface Props {
  size?: "small" | "wide";
  image?: string;
  title: string;
  description: string;
  href?: string;
}
const { size = "small", image, title, description, href = "#" } = Astro.props;
---

<a
  class="card"
  class:list={[`card--${size}`, { "card--placeholder": !image }]}
  href={href}
>
  <div class="card__media">
    {image && <img class="card__img" src={image} alt={title} loading="lazy" />}
  </div>
  <h3 class="card__title"><span class="card__title-text">{title}</span></h3>
  <p class="card__desc">{description}</p>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    color: var(--color-texto);
  }

  /* Ocupa 1 o 2 columnas del grid */
  .card--small {
    grid-column: span 1;
  }
  .card--wide {
    grid-column: span 2;
  }

  .card__media {
    aspect-ratio: 360 / 360;
    overflow: hidden;
    background: transparent;
  }
  .card--wide .card__media {
    aspect-ratio: 750 / 360;
  }
  .card--placeholder .card__media {
    background: var(--color-gris-placeholder);
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  /* Hover: la imagen se amplía suavemente */
  .card:hover .card__img {
    transform: scale(1.06);
  }

  .card__title {
    font-family: var(--fuente-titulo);
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    font-weight: 700;
    line-height: 1.2;
    margin-top: 1.25rem;
  }
  /* Subrayado amarillo animado de izquierda a derecha (abraza el texto) */
  .card__title-text {
    display: inline;
    background-image: linear-gradient(var(--color-amarillo), var(--color-amarillo));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 0.28em;
    transition: background-size 0.4s ease;
    padding-bottom: 0.05em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  .card:hover .card__title-text {
    background-size: 100% 0.28em;
  }
  .card__desc {
    font-size: 0.9rem;
    line-height: 1.55;
    color: #4a4a4a;
    margin-top: 0.6rem;
  }

  @media (max-width: 720px) {
    /* En móvil todas las tarjetas ocupan el ancho completo */
    .card--wide,
    .card--small {
      grid-column: span 1;
    }
    .card--wide .card__media {
      aspect-ratio: 16 / 9;
    }
  }
</style>
