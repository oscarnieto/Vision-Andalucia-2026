---
interface Props {
  size?: "small" | "wide";
  image?: string;
  title: string;
  description: string;
  href?: string;
}
const { size = "small", image, title, description, href = "#" } = Astro.props;
---

<a
  class="card"
  class:list={[`card--${size}`, { "card--placeholder": !image }]}
  href={href}
>
  <div class="card__media">
    {image && <img class="card__img" src={image} alt={title} loading="lazy" />}
  </div>
  <h3 class="card__title">{title}</h3>
  <p class="card__desc">{description}</p>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    color: var(--color-texto);
    transition: transform 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
  }
  .card:hover .card__title {
    text-decoration: underline;
  }

  /* Ocupa 1 o 2 columnas del grid */
  .card--small {
    grid-column: span 1;
  }
  .card--wide {
    grid-column: span 2;
  }

  .card__media {
    aspect-ratio: 360 / 360;
    border-radius: 8px;
    overflow: hidden;
    background: transparent;
  }
  .card--wide .card__media {
    aspect-ratio: 750 / 360;
  }
  .card--placeholder .card__media {
    background: var(--color-gris-placeholder);
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card__title {
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    font-weight: 700;
    line-height: 1.25;
    margin-top: 1.25rem;
  }
  .card__desc {
    font-size: 0.9rem;
    line-height: 1.55;
    color: #4a4a4a;
    margin-top: 0.6rem;
  }

  @media (max-width: 720px) {
    /* En móvil todas las tarjetas ocupan el ancho completo */
    .card--wide,
    .card--small {
      grid-column: span 1;
    }
    .card--wide .card__media {
      aspect-ratio: 16 / 9;
    }
  }
</style>
