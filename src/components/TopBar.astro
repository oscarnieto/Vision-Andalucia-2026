---
interface NavItem {
  label: string;
  href: string;
  strong?: boolean;
}
interface Props {
  nav: NavItem[];
}
import { asset } from "../lib/asset";

const { nav } = Astro.props;
const base = import.meta.env.BASE_URL;

// Submenú común a todas las secciones (excepto "Ediciones anteriores")
const submenu = [
  { label: "Málaga", href: "#" },
  { label: "Sevilla", href: "#" },
];
---

<header class="topbar">
  <!-- Franja amarilla con el logo -->
  <div class="topbar__brand">
    <a class="logo" href={base} aria-label="Visión Andalucía — Inicio">
      <img
        class="logo__img"
        src={asset("img/vision-andalucia-logo-topbar.svg")}
        alt="Visión Andalucía"
        width="310"
        height="26"
      />
    </a>
  </div>

  <!-- Menú de navegación -->
  <nav class="topmenu" aria-label="Navegación principal">
    <button
      class="topmenu__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="menu-principal"
    >
      <span class="topmenu__toggle-bar"></span>
      <span class="visually-hidden">Abrir menú</span>
    </button>

    <ul class="topmenu__list" id="menu-principal">
      <li class="topmenu__only-mobile">
        <a href={base} data-label="Inicio" class="topmenu__link">
          <span class="topmenu__link-text">Inicio</span>
        </a>
      </li>
      {
        nav.map((item) => (
          <li class:list={["topmenu__item", { "topmenu__item--has-sub": !item.strong }]}>
            <a
              href={item.href}
              data-label={item.label}
              class:list={["topmenu__link", { "topmenu__link--strong": item.strong }]}
            >
              <span class="topmenu__link-text">{item.label}</span>
            </a>
            {!item.strong && (
              <ul class="submenu" aria-label={`Ediciones de ${item.label}`}>
                {submenu.map((s) => (
                  <li>
                    <a class="submenu__link" href={s.href}>
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
      <li class="topmenu__only-mobile topmenu__savills">
        <a href="https://www.savills.es" data-label="savills.es" class="topmenu__link">
          <span class="topmenu__link-text">savills.es</span>
        </a>
      </li>
    </ul>

    <!-- Panel de submenú (solo móvil): se abre al tocar una sección -->
    <div class="topmenu__submobile">
      <p class="topmenu__submobile-title"></p>
      <a class="topmenu__submobile-link" href="#">Málaga</a>
      <a class="topmenu__submobile-link" href="#">Sevilla</a>
      <button class="topmenu__back" type="button">volver</button>
      <a class="topmenu__submobile-savills" href="https://www.savills.es">savills.es</a>
    </div>

    <!-- Marcador amarillo que se desliza entre enlaces (solo escritorio) -->
    <span class="topmenu__marker" aria-hidden="true"></span>
  </nav>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 500;
    width: 100%;
  }

  /* --- Franja amarilla + logo --- */
  .topbar__brand {
    height: var(--altura-topbar);
    background: var(--color-amarillo);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo {
    display: inline-flex;
    align-items: center;
  }
  .logo__img {
    height: clamp(18px, 2vw, 24px);
    width: auto;
    max-width: 85vw;
    display: block;
  }

  /* --- Menú --- */
  .topmenu {
    height: var(--altura-menu);
    background: var(--color-blanco);
    border-top: 1px solid var(--color-linea);
    border-bottom: 1px solid var(--color-linea);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .topmenu__list {
    list-style: none;
    display: flex;
    align-items: stretch;
    gap: 10px;
    height: 100%;
  }

  .topmenu__list li {
    display: flex;
  }

  /* "Inicio" y "savills.es" solo se muestran en el menú móvil.
     Se usa especificidad alta para ganar a `.topmenu__list li`. */
  .topmenu__list li.topmenu__only-mobile {
    display: none;
  }

  /* Cada enlace reserva el ancho de su versión en negrita (::before oculto),
     así al pasar a bold en hover el resto del menú no se desplaza. */
  .topmenu__link {
    position: relative;
    z-index: 1;
    display: inline-grid;
    place-items: center;
    height: 100%;
    padding: 0 8px;
    font-size: 0.75rem;
    color: var(--color-negro);
    white-space: nowrap;
  }
  .topmenu__link::before {
    grid-area: 1 / 1;
    content: attr(data-label);
    font-weight: 700;
    visibility: hidden;
  }
  .topmenu__link-text {
    grid-area: 1 / 1;
    font-weight: 400;
    transition: font-weight 0.1s ease;
  }
  .topmenu__link:hover .topmenu__link-text,
  .topmenu__link--strong .topmenu__link-text {
    font-weight: 700;
  }

  /* Marcador amarillo deslizante */
  .topmenu__marker {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    background: var(--color-amarillo);
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transform: translateX(0);
    transition: transform 0.3s ease, width 0.3s ease, opacity 0.2s ease;
  }

  /* --- Submenú desplegable (escritorio) --- */
  .topmenu__item {
    position: relative;
  }
  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    /* Se adapta al texto más largo, pero nunca más estrecho que el enlace */
    min-width: 100%;
    width: max-content;
    list-style: none;
    background: var(--color-blanco);
    border: 1px solid var(--color-linea);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    padding: 4px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 60;
  }
  .topmenu__item--has-sub:hover .submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .submenu__link {
    display: block;
    padding: 9px 18px;
    font-size: 0.8rem;
    color: var(--color-negro);
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .submenu__link:hover {
    background: var(--color-amarillo);
    font-weight: 700;
  }

  /* Panel de submenú móvil: oculto en escritorio */
  .topmenu__submobile {
    display: none;
  }

  /* --- Botón hamburguesa (oculto en escritorio) --- */
  .topmenu__toggle {
    display: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ============ Responsive (menú móvil: overlay a pantalla completa) ============ */
  @media (max-width: 900px) {
    /* La barra del menú deja de ser visible: solo sirve de contenedor */
    .topmenu {
      height: 0;
      background: transparent;
      border: none;
      position: static;
    }

    /* En móvil no hay marcador, reserva de negrita ni submenús de hover */
    .topmenu__marker {
      display: none;
    }
    .topmenu__link::before {
      display: none;
    }
    .submenu {
      display: none;
    }

    /* Los enlaces "solo móvil" (Inicio, savills.es) aparecen */
    .topmenu__list li.topmenu__only-mobile {
      display: block;
    }

    /* --- Botón burger / X, fijo (sticky) en una caja amarilla --- */
    .topmenu__toggle {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      position: fixed;
      top: calc(var(--altura-topbar) + 10px);
      right: 10px;
      width: 56px;
      height: 56px;
      background: var(--color-amarillo);
      border: none;
      cursor: pointer;
      padding: 0;
      z-index: 120;
    }
    .topmenu__toggle-bar,
    .topmenu__toggle-bar::before,
    .topmenu__toggle-bar::after {
      content: "";
      display: block;
      width: 26px;
      height: 2px;
      background: var(--color-negro);
      transition: transform 0.25s ease, opacity 0.2s ease;
    }
    .topmenu__toggle-bar {
      position: relative;
    }
    .topmenu__toggle-bar::before {
      position: absolute;
      top: -8px;
    }
    .topmenu__toggle-bar::after {
      position: absolute;
      top: 8px;
    }
    /* burger -> X al abrir */
    .topmenu[data-open="true"] .topmenu__toggle-bar {
      background: transparent;
    }
    .topmenu[data-open="true"] .topmenu__toggle-bar::before {
      transform: translateY(8px) rotate(45deg);
    }
    .topmenu[data-open="true"] .topmenu__toggle-bar::after {
      transform: translateY(-8px) rotate(-45deg);
    }

    /* --- Overlay amarillo a pantalla completa --- */
    .topmenu__list {
      position: fixed;
      top: var(--altura-topbar);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      height: auto;
      background: var(--color-amarillo);
      padding: clamp(0.75rem, 2.4vh, 2rem) var(--margen-lateral);
      /* El menú entra completo sin scroll: los tamaños escalan con la altura */
      overflow: hidden;
      z-index: 110;
      /* animación de apertura: se despliega de arriba hacia abajo (cortina) */
      clip-path: inset(0 0 100% 0);
      visibility: hidden;
      opacity: 1;
      transform: translateX(0);
      transition: clip-path 0.6s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0.8s, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .topmenu[data-open="true"] .topmenu__list {
      clip-path: inset(0 0 0 0);
      visibility: visible;
    }

    .topmenu__link {
      display: inline-block;
      height: auto;
      /* El tamaño escala con la altura para que todo quepa sin scroll */
      padding: clamp(0.1rem, 0.8vh, 0.5rem) 0;
      font-size: clamp(1rem, 3.4vh, 1.9rem);
      line-height: 1.1;
      color: var(--color-negro);
    }
    /* En el overlay, "Ediciones anteriores" no va en negrita por defecto */
    .topmenu__link--strong .topmenu__link-text {
      font-weight: 400;
    }

    /* savills.es: empujado al fondo y en rojo */
    .topmenu__savills {
      margin-top: auto;
      padding-top: clamp(0.75rem, 2vh, 1.75rem);
    }
    .topmenu__savills .topmenu__link {
      color: #8a2531;
    }
    .topmenu__savills .topmenu__link-text {
      font-weight: 700;
    }

    /* --- Segundo nivel (submenú de sección): transición push --- */
    /* Al abrir un submenú, el nivel 1 se desliza por completo a la izquierda
       (opaco, sin fundido, para que nunca se vean los dos paneles a la vez) */
    .topmenu[data-sub] .topmenu__list {
      transform: translateX(-100%);
      pointer-events: none;
    }

    .topmenu__submobile {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      position: fixed;
      top: var(--altura-topbar);
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-amarillo);
      padding: clamp(0.75rem, 2.4vh, 2rem) var(--margen-lateral);
      z-index: 111;
      /* Fuera de pantalla a la derecha; entra deslizándose (opaco) */
      visibility: hidden;
      transform: translateX(100%);
      transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0.8s;
    }
    .topmenu[data-sub] .topmenu__submobile {
      visibility: visible;
      transform: translateX(0);
    }

    .topmenu__submobile-title {
      font-size: clamp(1.1rem, 4.4vh, 2.1rem);
      font-weight: 700;
      line-height: 1.1;
      padding-block: clamp(0.1rem, 0.8vh, 0.5rem);
      margin-bottom: clamp(0.3rem, 1.5vh, 0.9rem);
    }
    .topmenu__submobile-link,
    .topmenu__back {
      font-size: clamp(1rem, 3.4vh, 1.9rem);
      line-height: 1.1;
      padding: clamp(0.1rem, 0.8vh, 0.5rem) 0;
      color: var(--color-negro);
    }
    .topmenu__submobile-link:hover,
    .topmenu__back:hover {
      font-weight: 700;
    }
    .topmenu__back {
      margin-top: clamp(1rem, 3.5vh, 2.25rem);
      background: none;
      border: none;
      font-family: inherit;
      font-weight: 700;
      cursor: pointer;
    }
    .topmenu__submobile-savills {
      margin-top: auto;
      padding-top: clamp(0.75rem, 2vh, 1.75rem);
      font-size: clamp(1rem, 3.4vh, 1.9rem);
      font-weight: 700;
      color: #8a2531;
    }
  }
</style>

<script>
  const menu = document.querySelector<HTMLElement>(".topmenu");
  const toggle = menu?.querySelector<HTMLButtonElement>(".topmenu__toggle");

  const subTitle = menu?.querySelector<HTMLElement>(".topmenu__submobile-title");
  const backBtn = menu?.querySelector<HTMLButtonElement>(".topmenu__back");
  const isMobile = () => window.matchMedia("(max-width: 900px)").matches;

  const setOpen = (open: boolean) => {
    menu?.setAttribute("data-open", String(open));
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
    // Al cerrar, vuelve siempre al primer nivel
    if (!open) menu?.removeAttribute("data-sub");
    // Bloquea el scroll del fondo mientras el overlay está abierto
    document.body.style.overflow = open ? "hidden" : "";
  };

  toggle?.addEventListener("click", () => {
    const open = menu?.getAttribute("data-open") === "true";
    setOpen(!open);
  });

  // Comportamiento de los enlaces del menú
  menu?.querySelectorAll<HTMLElement>(".topmenu__link").forEach((link) => {
    link.addEventListener("click", (e) => {
      const li = link.closest(".topmenu__item");
      const hasSub = li?.classList.contains("topmenu__item--has-sub");
      if (isMobile() && hasSub) {
        // En móvil, tocar una sección abre su submenú (no navega)
        e.preventDefault();
        if (subTitle) subTitle.textContent = link.textContent?.trim() ?? "";
        menu?.setAttribute("data-sub", "true");
      } else {
        // Inicio, Ediciones anteriores, savills.es o escritorio: navega y cierra
        setOpen(false);
      }
    });
  });

  // "volver" regresa al primer nivel
  backBtn?.addEventListener("click", () => menu?.removeAttribute("data-sub"));

  // Los enlaces de ciudad cierran el menú
  menu?.querySelectorAll(".topmenu__submobile-link").forEach((link) =>
    link.addEventListener("click", () => setOpen(false))
  );

  // Escape: si hay submenú abierto vuelve al nivel 1; si no, cierra el menú
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    if (menu?.hasAttribute("data-sub")) {
      menu.removeAttribute("data-sub");
    } else if (menu?.getAttribute("data-open") === "true") {
      setOpen(false);
    }
  });

  // Marcador amarillo deslizante (solo con puntero, escritorio)
  const marker = menu?.querySelector<HTMLElement>(".topmenu__marker");
  const links = menu?.querySelectorAll<HTMLElement>(".topmenu__link");
  let markerVisible = false;

  const moveMarker = (link: HTMLElement) => {
    if (!marker || !menu) return;
    const lr = link.getBoundingClientRect();
    const mr = menu.getBoundingClientRect();
    // El marcador amarillo ocupa solo el ancho de cada enlace
    if (!markerVisible) marker.style.transition = "none";
    marker.style.width = `${lr.width}px`;
    marker.style.transform = `translateX(${lr.left - mr.left}px)`;
    if (!markerVisible) {
      // fuerza reflow para que la primera aparición no se deslice desde 0
      void marker.offsetWidth;
      marker.style.transition = "";
      marker.style.opacity = "1";
      markerVisible = true;
    }
  };

  const canHover = window.matchMedia("(hover: hover) and (min-width: 901px)");
  if (canHover.matches) {
    links?.forEach((link) =>
      link.addEventListener("mouseenter", () => moveMarker(link))
    );
    menu?.addEventListener("mouseleave", () => {
      if (marker) marker.style.opacity = "0";
      markerVisible = false;
    });
  }
</script>
