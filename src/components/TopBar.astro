---
interface NavItem {
  label: string;
  href: string;
  strong?: boolean;
}
interface Props {
  nav: NavItem[];
}
const { nav } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="topbar">
  <!-- Franja amarilla con el logo -->
  <div class="topbar__brand">
    <a class="logo" href={base} aria-label="Visión Andalucía — Inicio">
      <span class="logo__vision">VISIÓN</span>
      <span class="logo__sep" aria-hidden="true">|</span>
      <span class="logo__andalucia">ANDALUCÍA</span>
    </a>
  </div>

  <!-- Menú de navegación -->
  <nav class="topmenu" aria-label="Navegación principal">
    <button
      class="topmenu__toggle"
      type="button"
      aria-expanded="false"
      aria-controls="menu-principal"
    >
      <span class="topmenu__toggle-bar"></span>
      <span class="visually-hidden">Abrir menú</span>
    </button>

    <ul class="topmenu__list" id="menu-principal">
      <li class="topmenu__only-mobile">
        <a href={base} data-label="Inicio" class="topmenu__link">
          <span class="topmenu__link-text">Inicio</span>
        </a>
      </li>
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              data-label={item.label}
              class:list={["topmenu__link", { "topmenu__link--strong": item.strong }]}
            >
              <span class="topmenu__link-text">{item.label}</span>
            </a>
          </li>
        ))
      }
      <li class="topmenu__only-mobile topmenu__savills">
        <a href="https://www.savills.es" data-label="savills.es" class="topmenu__link">
          <span class="topmenu__link-text">savills.es</span>
        </a>
      </li>
    </ul>

    <!-- Marcador amarillo que se desliza entre enlaces (solo escritorio) -->
    <span class="topmenu__marker" aria-hidden="true"></span>
  </nav>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  /* --- Franja amarilla + logo --- */
  .topbar__brand {
    height: var(--altura-topbar);
    background: var(--color-amarillo);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(1rem, 2.4vw, 1.25rem);
    letter-spacing: 0.12em;
    color: var(--color-negro);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .logo__vision {
    font-weight: 400;
  }
  .logo__sep {
    font-weight: 300;
    opacity: 0.6;
  }
  .logo__andalucia {
    font-weight: 800;
  }

  /* --- Menú --- */
  .topmenu {
    height: var(--altura-menu);
    background: var(--color-blanco);
    border-top: 1px solid var(--color-linea);
    border-bottom: 1px solid var(--color-linea);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .topmenu__list {
    list-style: none;
    display: flex;
    align-items: stretch;
    gap: 10px;
    height: 100%;
  }

  .topmenu__list li {
    display: flex;
  }

  /* "Inicio" y "savills.es" solo se muestran en el menú móvil */
  .topmenu__only-mobile {
    display: none;
  }

  /* Cada enlace reserva el ancho de su versión en negrita (::before oculto),
     así al pasar a bold en hover el resto del menú no se desplaza. */
  .topmenu__link {
    position: relative;
    z-index: 1;
    display: inline-grid;
    place-items: center;
    height: 100%;
    padding: 0 8px;
    font-size: 0.75rem;
    color: var(--color-negro);
    white-space: nowrap;
  }
  .topmenu__link::before {
    grid-area: 1 / 1;
    content: attr(data-label);
    font-weight: 700;
    visibility: hidden;
  }
  .topmenu__link-text {
    grid-area: 1 / 1;
    font-weight: 400;
    transition: font-weight 0.1s ease;
  }
  .topmenu__link:hover .topmenu__link-text,
  .topmenu__link--strong .topmenu__link-text {
    font-weight: 700;
  }

  /* Marcador amarillo deslizante */
  .topmenu__marker {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 0;
    background: var(--color-amarillo);
    opacity: 0;
    z-index: 0;
    pointer-events: none;
    transform: translateX(0);
    transition: transform 0.3s ease, width 0.3s ease, opacity 0.2s ease;
  }

  /* --- Botón hamburguesa (oculto en escritorio) --- */
  .topmenu__toggle {
    display: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  /* ============ Responsive (menú móvil: overlay a pantalla completa) ============ */
  @media (max-width: 900px) {
    /* La barra del menú deja de ser visible: solo sirve de contenedor */
    .topmenu {
      height: 0;
      background: transparent;
      border: none;
      position: static;
    }

    /* En móvil no hay marcador ni reserva de negrita */
    .topmenu__marker {
      display: none;
    }
    .topmenu__link::before {
      display: none;
    }

    /* Los enlaces "solo móvil" (Inicio, savills.es) aparecen */
    .topmenu__only-mobile {
      display: block;
    }

    /* --- Botón burger / X, fijo (sticky) en una caja amarilla --- */
    .topmenu__toggle {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
      position: fixed;
      top: calc(var(--altura-topbar) + 10px);
      right: 10px;
      width: 56px;
      height: 56px;
      background: var(--color-amarillo);
      border: none;
      cursor: pointer;
      padding: 0;
      z-index: 120;
    }
    .topmenu__toggle-bar,
    .topmenu__toggle-bar::before,
    .topmenu__toggle-bar::after {
      content: "";
      display: block;
      width: 26px;
      height: 2px;
      background: var(--color-negro);
      transition: transform 0.25s ease, opacity 0.2s ease;
    }
    .topmenu__toggle-bar {
      position: relative;
    }
    .topmenu__toggle-bar::before {
      position: absolute;
      top: -8px;
    }
    .topmenu__toggle-bar::after {
      position: absolute;
      top: 8px;
    }
    /* burger -> X al abrir */
    .topmenu[data-open="true"] .topmenu__toggle-bar {
      background: transparent;
    }
    .topmenu[data-open="true"] .topmenu__toggle-bar::before {
      transform: translateY(8px) rotate(45deg);
    }
    .topmenu[data-open="true"] .topmenu__toggle-bar::after {
      transform: translateY(-8px) rotate(-45deg);
    }

    /* --- Overlay amarillo a pantalla completa --- */
    .topmenu__list {
      position: fixed;
      top: var(--altura-topbar);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      height: auto;
      background: var(--color-amarillo);
      padding: clamp(1.5rem, 7vw, 3rem) var(--margen-lateral)
        clamp(2rem, 8vw, 3.5rem);
      overflow-y: auto;
      z-index: 110;
      /* animación de apertura */
      opacity: 0;
      transform: translateY(-14px);
      visibility: hidden;
      transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s;
    }
    .topmenu[data-open="true"] .topmenu__list {
      opacity: 1;
      transform: translateY(0);
      visibility: visible;
    }

    .topmenu__link {
      display: inline-block;
      height: auto;
      padding: 0.5rem 0;
      font-size: clamp(1.5rem, 6vw, 2rem);
      color: var(--color-negro);
    }
    /* En el overlay, "Ediciones anteriores" no va en negrita por defecto */
    .topmenu__link--strong .topmenu__link-text {
      font-weight: 400;
    }

    /* savills.es: empujado al fondo y en rojo */
    .topmenu__savills {
      margin-top: auto;
      padding-top: 2rem;
    }
    .topmenu__savills .topmenu__link {
      color: #8a2531;
    }
    .topmenu__savills .topmenu__link-text {
      font-weight: 700;
    }
  }
</style>

<script>
  const menu = document.querySelector<HTMLElement>(".topmenu");
  const toggle = menu?.querySelector<HTMLButtonElement>(".topmenu__toggle");

  const setOpen = (open: boolean) => {
    menu?.setAttribute("data-open", String(open));
    toggle?.setAttribute("aria-expanded", String(open));
    toggle?.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
    // Bloquea el scroll del fondo mientras el overlay está abierto
    document.body.style.overflow = open ? "hidden" : "";
  };

  toggle?.addEventListener("click", () => {
    const open = menu?.getAttribute("data-open") === "true";
    setOpen(!open);
  });

  // Cierra el menú al pulsar un enlace (en móvil)
  menu?.querySelectorAll(".topmenu__link").forEach((link) =>
    link.addEventListener("click", () => setOpen(false))
  );

  // Cierra con la tecla Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menu?.getAttribute("data-open") === "true") {
      setOpen(false);
    }
  });

  // Marcador amarillo deslizante (solo con puntero, escritorio)
  const marker = menu?.querySelector<HTMLElement>(".topmenu__marker");
  const links = menu?.querySelectorAll<HTMLElement>(".topmenu__link");
  let markerVisible = false;

  const moveMarker = (link: HTMLElement) => {
    if (!marker || !menu) return;
    const lr = link.getBoundingClientRect();
    const mr = menu.getBoundingClientRect();
    if (!markerVisible) marker.style.transition = "none";
    marker.style.width = `${lr.width}px`;
    marker.style.transform = `translateX(${lr.left - mr.left}px)`;
    if (!markerVisible) {
      // fuerza reflow para que la primera aparición no se deslice desde 0
      void marker.offsetWidth;
      marker.style.transition = "";
      marker.style.opacity = "1";
      markerVisible = true;
    }
  };

  const canHover = window.matchMedia("(hover: hover) and (min-width: 901px)");
  if (canHover.matches) {
    links?.forEach((link) =>
      link.addEventListener("mouseenter", () => moveMarker(link))
    );
    menu?.addEventListener("mouseleave", () => {
      if (marker) marker.style.opacity = "0";
      markerVisible = false;
    });
  }
</script>
